# 环境变量示例文件
# 复制此文件为 .env 并填入实际值

# 代理配置
PROXY_ENABLED=false
PROXY_SERVER=http://localhost:7890
PROXY_USERNAME=
PROXY_PASSWORD=

# 地理位置
GEOLOCATION_ENABLED=false
GEO_PROVINCE=广东省
GEO_CITY=深圳市

# 浏览器配置
BROWSER_HEADLESS=true
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1080

# 并发控制
CONCURRENCY_ENABLED=true
MAX_WORKERS=5
BATCH_SIZE=10

# 日志级别
LOG_LEVEL=INFO

# 重试配置
MAX_ATTEMPTS=3
RETRY_DELAY=2
